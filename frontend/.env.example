# Recovery Road — frontend (Vite). Copy to .env.production or .env.local as needed.

# Same host as API (default): leave unset — uses relative /api and current origin for sockets.

# If the API is on another domain (e.g. https://api.myapp.com):
# VITE_API_ORIGIN=https://api.myapp.com

# Socket.IO server URL (usually same as API). If unset, uses VITE_API_ORIGIN, or dev → localhost:5000.
# VITE_SOCKET_URL=https://api.myapp.com

# Dev only — where `npm run dev` proxies /api (see vite.config.js)
# VITE_DEV_PROXY_TARGET=http://127.0.0.1:5000
# VITE_DEV_PORT=5180
