# Recovery Road — backend environment (copy to .env and fill in)
NODE_ENV=production
PORT=5000

# MongoDB
MONGO_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/recoveryroad

# JWT / auth — use long random strings in production
JWT_SECRET=change-me
JWT_EXPIRE=7d

# CORS / realtime — required in production when frontend is on another origin
# Single site:
# FRONTEND_URL=https://your-app.onrender.com
# Multiple origins (comma-separated, no spaces after commas optional):
# ALLOWED_ORIGINS=https://app.example.com,https://www.example.com

# Optional: serve the Vite production build from this Node server
# SERVE_FRONTEND=true
# FRONTEND_DIST_PATH=/absolute/path/to/frontend/dist

# Python ML microservice (Flask, default http://127.0.0.1:5001)
# Node will spawn ml_service/app.py on startup unless disabled:
AUTO_START_ML_SERVICE=true
# ML_SERVICE_URL=http://127.0.0.1:5001
# ML_PYTHON=python
# On Windows if `python` fails, try: ML_PYTHON=py  (and ensure `py -3` works, or use full path to python.exe)

# SMTP_HOST=
# SMTP_USER=
